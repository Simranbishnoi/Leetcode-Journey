//not brute force but using methods in java string
class Solution {
    public String reverseWords(String s) {
       String[]words=s.trim().split("\\s+");      //not alone split(" ") if extra space btw two words is there it will consider space also as array element
       StringBuilder ans=new StringBuilder();
       for(int i=words.length-1;i>=0;i--){
        ans.append(words[i]);
        if(i!=0)              //necessary otherwise after last word it will print extra space
        ans.append(" ");
       }
       return ans.toString();

    }
}
//if asked without methods?without split .use substring
class Solution {
     public String reverseWords(String s) {
        StringBuilder ans=new StringBuilder();
        int i=s.length()-1;
        while(i>=0){
            
            while(i>=0 && s.charAt(i)==' ')
            i--;
            if(i<0)break;
            int j=i;
            while(j>=0 && s.charAt(j)!=' ')
            j--;
            ans.append(s.substring(j+1,i+1));
            ans.append(" ");
            i=j;
            
        }
        return ans.toString().trim();
     }
}     

class Solution {
    public char[] reverse(char[]chars,int left,int right){
        while(left<right){
            char temp=chars[left];
            chars[left]=chars[right];
            chars[right]=temp;
            left++;
            right--;
        }
        return chars;
    }
    public String reverseWords(String s) {
    //convert into char arry
    char[]chars=s.toCharArray();
    int n=chars.length;
    //reverse whole array
    int left=0; int right=chars.length-1;
    reverse(chars,left,right);
    //reverse words
    int i=0;
    while(i<n){
        while(i<n && chars[i]==' ')i++;
        if(i==n)break;
        int j=i;
        while(j<n && chars[j]!=' ')j++;

        reverse(chars,i,j-1);
        i=j;
    }
    //remove extra space from anywhere
    int read=0;
    int write=0;

    while(read<n){
        while(read<n && chars[read]==' ')
        read++;
        while(read<n && chars[read]!=' ')
        chars[write++]=chars[read++];
        while(read<n && chars[read]==' ')
        read++;
        if(read<n){
            chars[write++]=' ';
        }
    }
    return new String(chars,0,write);//0 is start and write is count and this si constructor
    }
}    
