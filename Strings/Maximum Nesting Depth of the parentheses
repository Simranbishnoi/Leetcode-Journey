class Solution {
    public int maxDepth(String s) {
        // ( is +1 and this )is -1 when we reach end of string ( )would become zero ,keep max count of depth
        int depth=0;
        int flag=0;
        for(int i=0;i<s.length();i++){
            if(s.charAt(i)=='('){
              flag++;
            }
            else if(s.charAt(i)==')'){
                flag--;
            }
            if(flag>=depth)
            depth=flag;

        }
        return depth;
    }
}
