//O(n) should think of all edge cases like comparing first element with second and last with last second as we can return any peak index 
class Solution {
    public int findPeakElement(int[] nums) {
        int n=nums.length;
        if(n==1)return 0;
       if(nums[0]>nums[1])return 0;
       if(nums[n-1]>nums[n-2])return n-1;
        else{
        for(int i=1;i<n-1;i++){
            if(nums[i]>nums[i-1] &&nums[i]>nums[i+1]){
              return i;
            }
        }
        }
       
        return -1;
    }
}
//O(log n)
class Solution {
    public int findPeakElement(int[] nums) {
        int n=nums.length;
        int low=0;
        int high=n-1;
        while(low<high){    //if mid==high then mid+1 will be out of bound so not low<=high
            int mid=(low+high)/2;
            if(nums[mid]<nums[mid+1])      //inc slope so peak on right side
            low=mid+1;
            else
            high=mid;    //including mid
        }
        return low;
    }
}
