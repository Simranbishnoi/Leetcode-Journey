class Solution {
    public int minEatingSpeed(int[] piles, int h) {
          int low=1;
          int high=0;
          for(int pile:piles){
            high=Math.max(high,pile);
          }
      while(low<high){
        int mid=low+(high-low)/2;
        int total=0;
        for(int pile:piles){
            total+=(pile+mid-1)/mid;  //ceil division
            if(total>h) break;
        }
        if(total<=h)high=mid;
        else low=mid+1;

      }
      return low;
    }
}    
