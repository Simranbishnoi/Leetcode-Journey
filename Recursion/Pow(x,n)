class Solution {
   public double myPow(double x, int n) { 
        // Use a long variable to safely prevent Integer.MIN_VALUE overflow
        long N = n; 
        if (N < 0) {
            x = 1 / x;
            N = -N;
        }
        return fastPow(x, N);
    }
    public double fastPow(double x, long n) {
        if(n==0)return 1;
        if(n<0)
        return 1/fastPow(x,-n);
      double half=fastPow(x,n/2);
      if(n%2==0)return half*half;
      else
      return x*half*half;
    }
}
