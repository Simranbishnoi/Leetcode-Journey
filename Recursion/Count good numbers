class Solution {
    public int countGoodNumbers(long n) {
        int odd_place=4;
        int even_place=5;
        long mod=1000000007;
        long res=1;
        for(int i=0;i<n;i++){
            if(i%2==0)
            res=(res*even_place)%mod;
            else
            res=(res*odd_place)%mod;
        }
        return(int) res ;
    }
}
