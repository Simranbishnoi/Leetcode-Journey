import java.util.Scanner;
class practice{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int arr[]=new int[n];
        arr[0]=0;
        arr[1]=1;
        fibonacci(arr,n,2);
        for(int i=0;i<n;i++)
            System.out.println(arr[i]);
    }
    public static void  fibonacci(int arr[],int n,int i){
          if(i==n)return;

          arr[i]=arr[i-1]+arr[i-2];
         fibonacci(arr,n,i+1);
    }
}
